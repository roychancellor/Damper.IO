<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${var:logDirectory}/internal-nlog.txt">

  <variable name="logDirectory" value="C:\logs" />
  
  <variable name="standardLayout" 
          value="${date:format=yyyy-MM-dd HH\:mm\:ss.fff}|${threadid:padding=4}|${mdlc:item=CorrelationId:default=----------}|${level:uppercase=true:padding=5}|${message}${onexception:${newline}${exception:format=tostring}}" />

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    
    <target xsi:type="File" name="applicationFile"
            fileName="${var:logDirectory}/Application.log"
            archiveFileName="${var:logDirectory}/archives/Application.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            maxArchiveFiles="30"
            maxArchiveDays="30"
            archiveAboveSize="10485760" concurrentWrites="true"
            keepFileOpen="true"
            bufferSize="32768"
            layout="${standardLayout}" />

    <target xsi:type="File" name="requestFile"
            fileName="${var:logDirectory}/Request.log"
            archiveFileName="${var:logDirectory}/archives/Request.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            maxArchiveFiles="30"
            maxArchiveDays="30"
            archiveAboveSize="10485760"
            concurrentWrites="true"
            keepFileOpen="true"
            bufferSize="32768"
            layout="${standardLayout}" />

    <target xsi:type="File" name="healthFile"
            fileName="${var:logDirectory}/Health.log"
            archiveFileName="${var:logDirectory}/archives/Health.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            maxArchiveFiles="30"
            maxArchiveDays="30"
            archiveAboveSize="10485760"
            concurrentWrites="true"
            keepFileOpen="true"
            bufferSize="32768"
            layout="${standardLayout}" />

    <target xsi:type="File" name="requestTraceFile"
            fileName="${var:logDirectory}/RequestTrace.log"
            archiveFileName="${var:logDirectory}/archives/RequestTrace.{#}.log"
            archiveEvery="Day"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            maxArchiveFiles="14"
            maxArchiveDays="14"
            archiveAboveSize="10485760"
            concurrentWrites="true"
            keepFileOpen="true"
            bufferSize="32768"
            layout="${standardLayout}" />

    <target xsi:type="ColoredConsole" name="lifetimeConsole" 
            layout="${date:format=HH\:mm\:ss.fff}|${threadid:padding=4}|${level:uppercase=true}|[${logger}] ${message}" />
  </targets>

  <rules>
    <logger name="Application" minlevel="Debug" writeTo="applicationFile,lifetimeConsole" final="true" />
    <logger name="Request" minlevel="Debug" writeTo="requestFile,lifetimeConsole" final="true" />
    <logger name="Health" minlevel="Debug" writeTo="healthFile,lifetimeConsole" final="true" />
    <logger name="RequestTrace" minlevel="Debug" writeTo="requestTraceFile" final="true" />

    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <logger name="*" minlevel="Info" writeTo="applicationFile,lifetimeConsole" />
  </rules>
</nlog>